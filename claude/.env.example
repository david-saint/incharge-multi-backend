# Application
APP_ENV=local
APP_PORT=8080
APP_URL=http://localhost:8080
APP_API_DOMAIN=localhost
APP_USER_DOMAIN=http://localhost:3000
APP_SESSION_SECRET=change-me-to-a-random-secret

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=incharge
DB_USERNAME=root
DB_PASSWORD=secret

# JWT
JWT_SECRET=change-me-to-a-random-jwt-secret
JWT_TTL_MINUTES=1440

# Mail (SMTP)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@incharge.app
MAIL_FROM_NAME=InCharge
