APP_ENV=local
PORT=3000
APP_URL=http://localhost:3000
APP_API_DOMAIN=http://localhost:3000
APP_USER_DOMAIN=http://localhost:5173

DB_CONNECTION=sqlite
DB_DATABASE=:memory:
DB_SYNCHRONIZE=true
AUTO_SEED=true

JWT_SECRET=change-me-secret
JWT_TTL_SECONDS=3600

SESSION_SECRET=change-me-session-secret
SESSION_STORE=memory

MAIL_ENABLED=false
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=

PASSWORD_RESET_EXPIRY_MINUTES=60
EMAIL_VERIFICATION_EXPIRY_MINUTES=4320
